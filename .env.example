# ─── Client-exposed variables (VITE_ prefix) ────────────────────────
# These are embedded into the client bundle at build time.
# Copy this file to .env and adjust values as needed.

# API prefix sent to the client — always /api when using the Vite dev proxy
VITE_API_URL=/api

# Public URL where this app is served
VITE_APP_URL=http://localhost:3000

# Environment identifier (development | staging | production)
VITE_APP_ENV=development

# Email of the preset default user, which must not be edited or deleted.
# Must match the default user seeded by the backend. Leave empty to disable
# this protection (no user is treated as the default user).
VITE_DEFAULT_USER_EMAIL=devnull@frachtwerk.de

# ─── Server-only variables (NOT embedded in client bundle) ───────────
# These are read by vite.config.ts only and never reach the browser.

# Target backend for the Vite dev proxy (/api → BACKEND_PROXY_TARGET)
# Override in .env.local or use pnpm dev:staging (.env.staging)
BACKEND_PROXY_TARGET=http://localhost:8098
