# ─── Client-exposed variables (VITE_ prefix) ────────────────────────
# These are embedded into the client bundle at build time.
# Copy this file to .env and adjust values as needed.

# Base URL of the backend API
VITE_API_URL=http://localhost:8098

# Public URL where this app is served
VITE_APP_URL=http://localhost:3000

# Environment identifier (development | staging | production)
VITE_APP_ENV=development
